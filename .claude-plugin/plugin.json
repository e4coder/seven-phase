{
  "name": "seven-phase",
  "version": "0.5.0",
  "description": "Human-gated 7-phase LLM programming pipeline: structs -> interfaces -> todos -> dry-run -> invariants -> implement.",
  "author": { "name": "Nomi" },
  "repository": "https://github.com/e4coder/seven-phase",
  "license": "MIT",
  "commands": "./commands",
  "mcpServers": {
    "forgejo": {
      "command": "gitea-mcp",
      "args": ["-t", "stdio", "-H", "${FORGEJO_HOST:-https://localhost:3000}"],
      "env": { "GITEA_ACCESS_TOKEN": "${FORGEJO_TOKEN:-}" }
    }
  }
}
